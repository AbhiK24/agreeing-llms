# Copy to .env and fill in. All keys optional — any provider without a key
# is skipped; you need at least the ones your experiment.yaml references.

# One key reaches all 8 models used in the default config.
OPENROUTER_API_KEY=

# Native fallbacks (only needed if you swap providers in experiment.yaml)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
TOGETHER_API_KEY=
